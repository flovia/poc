{
  "name": "cli",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "bun@1.3.13",
  "engines": {
    "bun": ">=1.3.13"
  },
  "scripts": {
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "bun test",
    "market:snapshot": "dotenvx run --ignore=MISSING_ENV_FILE -f ../../.env -f .env -- bun scripts/analytics/market-snapshot.ts",
    "verify": "bun run typecheck && bun test"
  },
  "dependencies": {
    "@dotenvx/dotenvx": "^1.64.0",
    "contracts": "workspace:*",
    "intelligence": "workspace:*",
    "sources": "workspace:*"
  },
  "devDependencies": {
    "@types/bun": "^1.3.13",
    "typescript": "^6.0.3"
  }
}
