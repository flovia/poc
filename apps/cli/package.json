{
  "name": "cli",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "bun@1.3.13",
  "engines": {
    "bun": ">=1.3.13"
  },
  "scripts": {
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "bun test",
    "db:reset": "dotenvx run -- bun scripts/reset-db.ts",
    "fixture:fetch-rpc": "dotenvx run -- bun scripts/fetch-rpc-fixture.ts",
    "ingest:fixtures": "dotenvx run -- bun scripts/ingest-fixtures.ts",
    "score": "dotenvx run -- bun scripts/score.ts",
    "aggregate": "dotenvx run -- bun scripts/aggregate.ts",
    "report": "dotenvx run -- bun scripts/report.ts",
    "verify:offline": "dotenvx run -- bun scripts/verify.ts",
    "verify:live": "dotenvx run -- bun scripts/verify-live.ts",
    "verify": "bun run typecheck && bun test && bun run verify:offline"
  },
  "dependencies": {
    "@dotenvx/dotenvx": "^1.64.0",
    "viem": "^2.48.4"
  },
  "devDependencies": {
    "@types/bun": "^1.3.13",
    "typescript": "^6.0.3"
  }
}
