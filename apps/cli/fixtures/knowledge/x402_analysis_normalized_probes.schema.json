{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://foxytanuki.local/schemas/x402-analysis/normalized-probes.schema.json",
  "title": "Normalized x402 probe records",
  "type": "object",
  "required": ["generatedFrom", "count", "probes"],
  "properties": {
    "generatedFrom": {
      "type": "array",
      "items": { "type": "string" }
    },
    "count": { "type": "integer", "minimum": 0 },
    "probes": {
      "type": "array",
      "items": { "$ref": "#/$defs/probe" }
    }
  },
  "$defs": {
    "probe": {
      "type": "object",
      "required": ["name", "artifact", "request", "response", "payment"],
      "properties": {
        "name": { "type": "string" },
        "artifact": { "type": "string" },
        "request": {
          "type": "object",
          "required": ["method", "url"],
          "properties": {
            "method": { "type": ["string", "null"] },
            "url": { "type": ["string", "null"], "format": "uri" }
          },
          "additionalProperties": true
        },
        "response": {
          "type": "object",
          "required": ["status", "ok", "paymentResponseHeader", "decodedPaymentResponse"],
          "properties": {
            "status": { "type": ["integer", "null"] },
            "ok": { "type": ["boolean", "null"] },
            "paymentResponseHeader": {
              "type": ["string", "null"],
              "enum": ["x-payment-response", "payment-response", null]
            },
            "decodedPaymentResponse": {
              "type": "object",
              "properties": {
                "success": { "type": "boolean" },
                "payer": { "type": "string" },
                "transaction": { "type": "string" },
                "network": { "type": "string" }
              },
              "additionalProperties": true
            }
          },
          "additionalProperties": true
        },
        "payment": {
          "type": "object",
          "required": [
            "status",
            "x402Version",
            "scheme",
            "network",
            "amount",
            "asset",
            "payTo",
            "resource"
          ],
          "properties": {
            "status": { "type": ["string", "null"] },
            "x402Version": { "type": ["integer", "null"] },
            "error": { "type": ["string", "object", "null"] },
            "scheme": { "type": ["string", "null"] },
            "network": { "type": ["string", "null"] },
            "amount": { "type": ["string", "null"], "pattern": "^[0-9]*$" },
            "asset": { "type": ["string", "null"] },
            "payTo": { "type": ["string", "null"] },
            "resource": { "type": ["string", "null"] }
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    }
  }
}
