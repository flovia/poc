{
  "name": "bff",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "bun@1.3.13",
  "engines": {
    "bun": ">=1.3.13"
  },
  "scripts": {
    "start": "bun src/server.ts",
    "seed:demo": "bun ./scripts/seed-demo.ts",
    "test": "bun test",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "verify:e2e": "bun ./scripts/verify-e2e.ts",
    "verify": "bun run typecheck && bun test && bun run verify:e2e"
  },
  "devDependencies": {
    "@types/bun": "^1.3.13",
    "typescript": "^6.0.3"
  }
}
