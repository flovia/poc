{
  "name": "bff",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "bun@1.3.13",
  "engines": {
    "bun": ">=1.3.13"
  },
  "scripts": {
    "start": "bun --env-file=../../.env src/server.ts",
    "analytics:snapshot": "bun --env-file=../../.env scripts/generate-analytics-snapshot.ts",
    "test": "bun test",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "verify": "bun run typecheck && bun test"
  },
  "dependencies": {
    "@aws-sdk/client-bedrock-runtime": "^3.1040.0",
    "@qvac/sdk": "^0.9.2",
    "@hit-pay/mpp": "beta",
    "@solana/kit": "^6.9.0",
    "@solana/mpp": "^0.5.2",
    "contracts": "workspace:*",
    "mppx": "^0.6.15",
    "sources": "workspace:*",
    "stripe": "^22.1.0",
    "viem": "^2.48.8"
  },
  "devDependencies": {
    "@types/bun": "^1.3.13",
    "typescript": "^6.0.3"
  }
}
