{
  "name": "flovia-poc",
  "private": true,
  "version": "0.1.0",
  "packageManager": "bun@1.3.13",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "format": "biome format --write .",
    "format:check": "biome format .",
    "verify": "cd apps/cli && bun run verify",
    "test": "cd apps/cli && bun test",
    "typecheck": "cd apps/cli && bun run typecheck"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.13"
  }
}
