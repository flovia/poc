{
  "name": "flovia-poc",
  "private": true,
  "version": "0.1.0",
  "packageManager": "bun@1.3.13",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "check:imports": "bun scripts/check-import-boundaries.ts",
    "dev:docker": "docker compose -f docker-compose.yml -f docker-compose.dev.yaml up --watch --build",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "verify": "bun run check:imports && bun scripts/run-workspace-script.ts verify",
    "test": "bun scripts/run-workspace-script.ts test",
    "typecheck": "bun scripts/run-workspace-script.ts typecheck"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.13",
    "@types/bun": "^1.3.13",
    "typescript": "^6.0.3"
  }
}
