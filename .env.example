ALCHEMY_API_KEY=
RPC_FAST_API_KEY=
DUNE_SIM_API_KEY=
GOLDRUSH_API_KEY=
BITQUERY_TOKEN=
ZERION_API_KEY=
X402_MARKET_FETCH_LIMIT=100
X402_MARKET_JSON_OUTPUT_PATH=./reports/x402-market-snapshot.json
X402_MARKET_MARKDOWN_OUTPUT_PATH=./reports/x402-market-summary.md
HITPAY_API_KEY=
HITPAY_WEBHOOK_SALT=
HITPAY_MPP_ENDPOINT=https://sandbox.mpp.hitpay.dev
STRIPE_SECRET_KEY=
MPPX_PRIVATE_KEY=
MPP_SECRET_KEY=
SOLANA_MPP_RECIPIENT=
SOLANA_MPP_NETWORK=devnet
SOLANA_MPP_CURRENCY=4zMMC9srt5Ri5X14GAgXhaHii3GnPAEERYPJgZJDncDU
SOLANA_MPP_SECRET_KEY=
# Optional override for the Solana RPC endpoint used by @solana/mpp.
# When unset, the SDK uses the public devnet RPC (https://api.devnet.solana.com),
# which periodically returns stale blockhashes and causes "Verification Failed".
# Set this to a Helius / QuickNode / Alchemy devnet endpoint to avoid that.
SOLANA_MPP_RPC_URL=
# Server-side payer wallet for the showcase "Pay with Solana wallet" button.
# Accepts either the Solana CLI keypair JSON array (64 numbers) or a base58-encoded
# 64-byte secret key. The wallet must hold devnet SOL (for fees) and devnet USDC.
SOLANA_MPP_PAYER_PRIVATE_KEY=
